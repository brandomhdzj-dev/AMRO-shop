# Copia este archivo a .env y pon tus credenciales reales
# NO subas el archivo .env a GitHub

# Google OAuth (consíguelas en Google Cloud Console)
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui

# Facebook OAuth (consíguelas en Facebook Developers)
FACEBOOK_CLIENT_ID=tu_facebook_app_id_aqui
FACEBOOK_CLIENT_SECRET=tu_facebook_app_secret_aqui